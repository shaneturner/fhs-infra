# Unified FHS Environment Variables

# --- Domain Config ---
# Local Development Defaults
SITE_DOMAIN=forresthill.localhost
FHSTV_DOMAIN=fhstv.localhost
API_DOMAIN=api.forresthill.localhost

# Production Examples (Uncomment and set in your .env)
# SITE_DOMAIN=forresthill.school.nz
# FHSTV_DOMAIN=fhstv.school.nz
# API_DOMAIN=calendar.forresthill.school.nz

# --- Global Config ---
CADDY_EMAIL=shane@forresthill.school.nz

# --- Database (Postgres) ---
DB_DATABASE=craft_pg
DB_USER=craft
DB_PASSWORD=craft

# --- Calendar Sync ---
# REQUIRED: The ID of the Google Calendar to synchronize.
GOOGLE_CALENDAR_ID=your_id_here
# Path (on your HOST) to your Google Service Account JSON credentials file.
# Default is ./apps/fhs-calendar-sync/semper-service-account.json
GOOGLE_APPLICATION_CREDENTIALS_PATH=./apps/fhs-calendar-sync/semper-service-account.json
# Internal path (DO NOT CHANGE unless modifying Dockerfile)
GOOGLE_APPLICATION_CREDENTIALS=/app/config/service-account.json

# --- Craft CMS ---
# Copy these from apps/forresthill-postgres/.env
CRAFT_APP_ID=
CRAFT_SECURITY_KEY=
DB_SERVER=postgres
DB_PORT=5432
DB_DRIVER=pgsql
