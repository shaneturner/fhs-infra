# Unified FHS Environment Variables

# --- Domain Config ---
SITE_DOMAIN=forresthill.localhost
FHSTV_DOMAIN=fhstv.localhost
API_DOMAIN=api.forresthill.localhost
CADDY_EMAIL=admin@forresthill.school.nz

# --- Database (Postgres) ---
DB_DATABASE=craft_pg
DB_USER=craft
DB_PASSWORD=craft
DB_SERVER=postgres
DB_PORT=5432
DB_DRIVER=pgsql
DB_SCHEMA=public

# --- Calendar Sync ---
GOOGLE_CALENDAR_ID=your_id_here
GOOGLE_APPLICATION_CREDENTIALS=/app/config/service-account.json

# --- Craft CMS ---
ENVIRONMENT=production
CRAFT_APP_ID=ForrestHillSchool
CRAFT_SECURITY_KEY=
PRIMARY_DOMAIN=forresthill.school.nz
DEFAULT_DOMAIN=forresthill.school.nz

# --- Performance (Production) ---
PHP_OPCACHE_ENABLE=1
PHP_OPCACHE_MEMORY_CONSUMPTION=256
PHP_OPCACHE_REVALIDATE_FREQ=0
PHP_OPCACHE_VALIDATE_TIMESTAMPS=0

# --- User/Group Mapping (Identify via `id -u` and `id -g`) ---
# In production, set these to match your 'deploy' user (usually 1001)
PUID=1000
PGID=1000

# --- Local Development Overrides ---
MAILPIT_SMTP_PORT=1025
